<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MindsEvo | Human Thinking in the Age of AI</title>
  <style>
    :root {
      --dark:       #071225;
      --dark-2:     #0c1f3f;
      --blue:       #2563eb;
      --blue-light: #3b82f6;
      --green:      #22c55e;
      --green-dk:   #16a34a;
      --accent:     #35e59b;
      --cyan:       #16b7e8;
      --text:       #0f172a;
      --muted:      #64748b;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html  { scroll-behavior: smooth; }
    body  {
      font-family: "SF Pro Display", "Helvetica Neue", Arial,
                   "Microsoft YaHei", "PingFang SC", sans-serif;
      background: #fff;
      color: var(--text);
      line-height: 1.65;
    }
    a { text-decoration: none; color: inherit; }

    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px clamp(20px, 4vw, 56px);
      background: rgba(7,18,37,0.88);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .brand {
      display: flex; align-items: center; gap: 11px;
      color: #fff; font-size: 22px; font-weight: 900; letter-spacing: -.4px;
    }
    .brand img {
      width: 40px; height: 40px; border-radius: 50%; object-fit: cover;
      border: 1.5px solid rgba(255,255,255,0.28);
    }
    .nav-links {
      display: flex; gap: 26px; align-items: center;
      font-size: 14.5px; font-weight: 600;
    }
    .nav-links a { color: rgba(255,255,255,0.78); transition: color .2s; }
    .nav-links a:hover { color: #fff; }
    .nav-cta {
      padding: 9px 20px; border-radius: 12px; font-weight: 800; font-size: 14px;
      background: linear-gradient(135deg, var(--blue), var(--green));
      color: #fff !important;
    }
    .hamburger {
      display: none; flex-direction: column; gap: 5px;
      cursor: pointer; padding: 4px;
    }
    .hamburger span {
      display: block; width: 23px; height: 2px;
      background: #fff; border-radius: 2px; transition: all .3s;
    }
    .mobile-menu {
      display: none; flex-direction: column; gap: 0;
      position: fixed; top: 64px; left: 0; right: 0; z-index: 199;
      background: rgba(7,18,37,0.97); backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(255,255,255,0.10);
      padding: 8px clamp(20px, 4vw, 56px) 20px;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu a {
      color: rgba(255,255,255,0.82); font-size: 16px; font-weight: 600;
      padding: 14px 0; border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .mobile-menu a:last-child { border-bottom: 0; }

    .hero {
      min-height: 100vh;
      padding-top: 64px;
      position: relative; overflow: hidden;
      background:
        linear-gradient(90deg,
          rgba(7,18,37,0.97) 0%,
          rgba(7,18,37,0.90) 38%,
          rgba(7,18,37,0.34) 62%,
          rgba(7,18,37,0.04) 100%),
        url("hero-thinking.png") center right / cover no-repeat;
      color: #fff;
      display: flex; align-items: center;
    }
    .hero::after {
      content: ""; position: absolute; inset: 0; pointer-events: none;
      background: radial-gradient(ellipse at 65% 30%,
        rgba(37,99,235,.18), transparent 42%);
    }
    .hero-inner {
      position: relative; z-index: 2;
      width: min(1180px, 100% - 40px);
      margin: 0 auto;
      padding: 88px 0 110px;
      max-width: 680px;
      margin-left: max(20px, calc((100vw - 1180px) / 2));
    }
    .hero-eyebrow {
      display: inline-block;
      font-size: 12px; font-weight: 700; letter-spacing: 2.5px;
      text-transform: uppercase; color: var(--accent);
      border: 1px solid rgba(53,229,155,.35);
      padding: 5px 15px; border-radius: 100px; margin-bottom: 28px;
    }
    .hero-question {
      font-size: clamp(17px, 2vw, 24px); font-weight: 500;
      color: rgba(255,255,255,.72); margin-bottom: 10px;
    }
    .hero h1 {
      font-size: clamp(50px, 6.5vw, 86px);
      font-weight: 950; line-height: 1.07; letter-spacing: -2.5px;
      margin-bottom: 34px;
    }
    .hero h1 em {
      font-style: normal;
      background: linear-gradient(135deg, var(--accent), var(--cyan));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .hero-desc {
      font-size: clamp(16px, 1.7vw, 20px); font-weight: 500;
      color: rgba(255,255,255,.78); line-height: 1.8;
      max-width: 540px; margin-bottom: 44px;
    }
    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; align-items: center; }
    .btn-primary {
      padding: 15px 30px; border-radius: 15px; font-weight: 800; font-size: 16px;
      background: linear-gradient(135deg, var(--blue), var(--green)); color: #fff;
      box-shadow: 0 14px 38px rgba(37,99,235,.28);
      transition: transform .2s, box-shadow .2s;
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 20px 46px rgba(37,99,235,.36); }
    .btn-outline {
      padding: 14px 28px; border-radius: 15px; font-weight: 700; font-size: 16px;
      border: 1.5px solid rgba(255,255,255,.55);
      background: rgba(255,255,255,.06); color: #fff;
      transition: background .2s;
    }
    .btn-outline:hover { background: rgba(255,255,255,.12); }
    .scroll-hint {
      position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%);
      z-index: 3; display: flex; flex-direction: column; align-items: center; gap: 6px;
      color: rgba(255,255,255,.55); font-size: 12px; font-weight: 600; letter-spacing: 1px;
    }
    .scroll-dot {
      width: 34px; height: 34px; border-radius: 50%;
      border: 1.5px solid rgba(255,255,255,.22);
      display: flex; align-items: center; justify-content: center; font-size: 15px;
      animation: bob 2s ease-in-out infinite;
    }
    @keyframes bob { 0%,100%{transform:translateY(0)} 50%{transform:translateY(5px)} }

    .section { padding: 96px clamp(20px, 4vw, 56px); }
    .section-inner { max-width: 1180px; margin: 0 auto; }
    .section-label {
      display: inline-block; font-size: 11.5px; font-weight: 700;
      letter-spacing: 2.5px; text-transform: uppercase;
      color: var(--blue); margin-bottom: 18px;
    }
    .section-title {
      font-size: clamp(32px, 4vw, 52px); font-weight: 950;
      line-height: 1.13; letter-spacing: -1.4px; margin-bottom: 18px;
    }
    .section-sub {
      font-size: clamp(16px, 1.6vw, 20px); color: var(--muted);
      font-weight: 500; max-width: 780px; line-height: 1.78; margin-bottom: 58px;
    }

    .challenge-section { background: #f8faff; }
    .challenge-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 28px;
    }
    .c-side { padding: 40px; border-radius: 22px; }
    .c-side.ai {
      background: linear-gradient(140deg, #0c1f3f, #1a3a6e); color: #fff;
    }
    .c-side.human {
      background: linear-gradient(140deg, #f0fdf4, #dcfce7); color: var(--text);
      border: 1.5px solid #bbf7d0;
    }
    .c-side-label {
      font-size: 11px; font-weight: 700; letter-spacing: 2px;
      text-transform: uppercase; margin-bottom: 14px; opacity: .65;
    }
    .c-side h3 { font-size: 26px; font-weight: 850; margin-bottom: 22px; line-height: 1.2; }
    .c-side.ai h3 { color: var(--accent); }
    .c-side.human h3 { color: var(--green-dk); }
    .c-list { list-style: none; display: flex; flex-direction: column; gap: 13px; }
    .c-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 15.5px; line-height: 1.55; }
    .c-list li .dot { width: 7px; height: 7px; border-radius: 50%; margin-top: 8px; flex-shrink: 0; }
    .c-side.ai .dot { background: var(--accent); }
    .c-side.human .dot { background: var(--green); }
    .c-side.ai .c-list li { color: rgba(255,255,255,.82); }
    .challenge-quote {
      margin-top: 52px; padding: 36px 44px; border-radius: 22px;
      background: linear-gradient(135deg, #071225, #1a3a6e); color: #fff; text-align: center;
    }
    .challenge-quote p {
      font-size: clamp(20px, 2.2vw, 29px); font-weight: 800;
      line-height: 1.5; letter-spacing: -.3px;
    }
    .challenge-quote p em { font-style: normal; color: var(--accent); }

    .mission-section { background: var(--dark); color: #fff; }
    .mission-section .section-label { color: var(--accent); }
    .mission-section .section-title { color: #fff; text-align: center; }
    .mission-section .section-sub {
      color: rgba(255,255,255,.60); text-align: center;
      margin-left: auto; margin-right: auto; margin-bottom: 36px;
    }
    .mission-question {
      max-width: 860px; margin: 0 auto 48px;
      padding: 40px 48px; border-radius: 22px;
      background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12);
      text-align: center;
    }
    .mission-question .q {
      font-size: clamp(20px, 2.4vw, 30px); font-weight: 800; font-style: italic;
      color: #fff; line-height: 1.45; margin-bottom: 16px;
    }
    .mission-question .a {
      font-size: 17px; color: rgba(255,255,255,.60); font-weight: 500; line-height: 1.75;
    }
    .mission-statement {
      max-width: 860px; margin: 0 auto 54px; text-align: center;
    }
    .mission-big {
      font-size: clamp(24px, 3vw, 40px); font-weight: 850;
      line-height: 1.38; letter-spacing: -.8px; color: rgba(255,255,255,.90);
    }
    .mission-big .dim { color: rgba(255,255,255,.28); }
    .mission-big .hi  { color: var(--accent); }
    .mission-note {
      margin-top: 22px; font-size: 17px;
      color: rgba(255,255,255,.48); font-weight: 500; line-height: 1.75;
    }
    .mission-pillars {
      display: grid; grid-template-columns: repeat(4,1fr); gap: 18px;
      max-width: 860px; margin: 0 auto;
    }
    .pillar {
      padding: 26px 22px; border-radius: 16px; text-align: center;
      background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.09);
    }
    .pillar-num {
      font-size: 11px; font-weight: 700; color: var(--accent);
      letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 10px;
    }
    .pillar h4 { font-size: 15px; font-weight: 800; color: #fff; margin-bottom: 8px; }
    .pillar p  { font-size: 13.5px; color: rgba(255,255,255,.50); line-height: 1.6; }

    .approach-section { background: #fff; }
    .thinking-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 22px; margin-bottom: 60px;
    }
    .t-card {
      padding: 34px 28px; border-radius: 20px;
      border: 1.5px solid #e4ecf8;
      transition: border-color .2s, box-shadow .2s;
    }
    .t-card:hover { border-color: var(--blue-light); box-shadow: 0 18px 48px rgba(37,99,235,.09); }
    .t-icon {
      width: 60px; height: 60px; border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      font-size: 28px; margin-bottom: 18px;
    }
    .t-en  { font-size: 12px; font-weight: 700; color: var(--blue); letter-spacing: 1.2px; text-transform: uppercase; margin-bottom: 6px; }
    .t-card h3 { font-size: 21px; font-weight: 850; margin-bottom: 10px; }
    .t-card p  { font-size: 14.5px; color: var(--muted); line-height: 1.65; }

    .rootgene-box {
      background: linear-gradient(135deg, #071225, #193260);
      border-radius: 26px; padding: 52px 56px; color: #fff;
    }
    .rg-label {
      font-size: 11.5px; font-weight: 700; color: var(--accent);
      letter-spacing: 2.5px; text-transform: uppercase; margin-bottom: 10px;
    }
    .rootgene-box h3 {
      font-size: clamp(26px, 3vw, 38px); font-weight: 900;
      letter-spacing: -.8px; margin-bottom: 14px;
    }
    .rootgene-box > p {
      font-size: 17px; color: rgba(255,255,255,.65);
      line-height: 1.78; max-width: 680px; margin-bottom: 40px;
    }
    .flow { display: flex; align-items: center; gap: 0; flex-wrap: nowrap; }
    .flow-step {
      flex: 1; min-width: 110px; text-align: center;
      padding: 20px 14px; border-radius: 16px;
      background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.11);
    }
    .flow-step .f-num  { font-size: 10px; font-weight: 700; color: var(--accent); letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 8px; }
    .flow-step .f-zh   { font-size: 22px; font-weight: 850; color: #fff; margin-bottom: 3px; }
    .flow-step .f-en   { font-size: 12px; color: rgba(255,255,255,.50); font-weight: 600; }
    .flow-arr          { color: var(--accent); font-size: 20px; padding: 0 8px; flex-shrink: 0; }

    .why-section { background: #f8faff; }
    .why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 52px; align-items: start; }
    .why-reasons { display: flex; flex-direction: column; gap: 22px; }
    .why-reason { display: flex; gap: 16px; align-items: flex-start; }
    .why-reason .ic {
      width: 46px; height: 46px; border-radius: 13px;
      background: #e8f0fe; display: flex; align-items: center;
      justify-content: center; font-size: 20px; flex-shrink: 0;
    }
    .why-reason h4 { font-size: 16px; font-weight: 800; margin-bottom: 4px; }
    .why-reason p  { font-size: 14px; color: var(--muted); line-height: 1.6; }
    .why-labs { display: flex; flex-direction: column; gap: 18px; }
    .why-labs-head {
      font-size: 11px; font-weight: 700; color: var(--muted);
      letter-spacing: 2px; text-transform: uppercase; margin-bottom: 4px;
    }
    .lab-card {
      padding: 26px 28px; border-radius: 18px;
      background: #fff; border: 1.5px solid #e0eaf8;
      box-shadow: 0 6px 26px rgba(15,23,42,.06);
    }
    .lab-card .lab-name { font-size: 19px; font-weight: 850; margin-bottom: 4px; }
    .lab-card .lab-sub  {
      font-size: 12px; font-weight: 700; color: var(--blue);
      letter-spacing: .8px; text-transform: uppercase; margin-bottom: 10px;
    }
    .lab-card p { font-size: 14px; color: var(--muted); line-height: 1.65; }
    .why-conclusion {
      margin-top: 52px; text-align: center; padding: 34px 40px;
      border-radius: 20px;
      background: linear-gradient(135deg, #1a3a6e, #071225);
      color: #fff; font-size: clamp(17px, 1.9vw, 23px);
      font-weight: 800; line-height: 1.55;
    }
    .why-conclusion em { font-style: normal; color: var(--accent); }
    .why-conclusion small { display:block; margin-top:10px; font-size:.75em; font-weight:500; color:rgba(255,255,255,.50); }

    .platform-section { background: #fff; }
    .platform-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 26px;
    }
    .p-card {
      border-radius: 22px; overflow: hidden;
      border: 1.5px solid #e2eaf8;
      transition: transform .2s, box-shadow .2s;
    }
    .p-card:hover { transform: translateY(-4px); box-shadow: 0 22px 56px rgba(37,99,235,.11); }
    .p-card.active { border-color: var(--blue); box-shadow: 0 14px 44px rgba(37,99,235,.14); }
    .p-head {
      padding: 30px 28px 24px; position: relative;
      background: linear-gradient(135deg, #071225, #1a3a6e); color: #fff;
    }
    .p-card.coming .p-head { background: linear-gradient(135deg, #1e293b, #334155); }
    .p-badge {
      position: absolute; top: 18px; right: 18px;
      padding: 4px 11px; border-radius: 100px;
      font-size: 10.5px; font-weight: 700; letter-spacing: .8px; text-transform: uppercase;
    }
    .badge-live { background: var(--accent); color: #071225; }
    .badge-soon { background: rgba(255,255,255,.14); color: rgba(255,255,255,.65); border: 1px solid rgba(255,255,255,.18); }
    .p-emoji { font-size: 42px; margin-bottom: 14px; display: block; }
    .p-head h3 { font-size: 24px; font-weight: 900; margin-bottom: 5px; }
    .p-head .p-lab { font-size: 12.5px; color: rgba(255,255,255,.55); font-style: italic; }
    .p-body { padding: 26px 28px 30px; background: #fff; }
    .p-card.coming .p-body { background: #f8fafc; }
    .p-body p { font-size: 15px; color: var(--muted); line-height: 1.7; margin-bottom: 20px; }
    .p-features { display: flex; flex-direction: column; gap: 9px; margin-bottom: 24px; }
    .p-feat { display: flex; align-items: center; gap: 9px; font-size: 13.5px; font-weight: 600; }
    .p-feat .ck { color: var(--green); font-size: 15px; }
    .p-feat.dim { color: var(--muted); }
    .p-feat.dim .ck { color: #cbd5e1; }
    .p-btn { display: block; width: 100%; padding: 13px; border-radius: 13px; text-align: center; font-size: 14.5px; font-weight: 800; }
    .p-btn.live { background: linear-gradient(135deg, var(--blue), var(--green)); color: #fff; }
    .p-btn.soon { background: #f1f5f9; color: var(--muted); cursor: default; }

    .join-section {
      background: linear-gradient(140deg, #071225 0%, #0d2454 55%, #071225 100%);
      color: #fff; text-align: center;
    }
    .join-section .section-label { color: var(--accent); }
    .join-section .section-title { color: #fff; }
    .join-section .section-sub {
      color: rgba(255,255,255,.60); margin-left: auto; margin-right: auto;
    }
    .join-form {
      max-width: 500px; margin: 0 auto 40px;
      display: flex; gap: 10px;
    }
    .join-form input {
      flex: 1; padding: 15px 20px; border-radius: 13px;
      border: 1.5px solid rgba(255,255,255,.18);
      background: rgba(255,255,255,.08); color: #fff;
      font-size: 15px; font-family: inherit; outline: none;
      transition: border-color .2s;
    }
    .join-form input::placeholder { color: rgba(255,255,255,.40); }
    .join-form input:focus { border-color: var(--accent); }
    .join-form button {
      padding: 15px 26px; border-radius: 13px; border: none;
      background: linear-gradient(135deg, var(--blue), var(--green));
      color: #fff; font-size: 15px; font-weight: 800;
      cursor: pointer; font-family: inherit; white-space: nowrap;
      transition: transform .2s;
    }
    .join-form button:hover { transform: translateY(-2px); }
    .join-social {
      display: flex; justify-content: center; gap: 16px; margin-bottom: 52px; flex-wrap: wrap;
    }
    .social-btn {
      display: flex; align-items: center; gap: 9px;
      padding: 13px 24px; border-radius: 13px;
      border: 1.5px solid rgba(255,255,255,.16);
      background: rgba(255,255,255,.06); color: rgba(255,255,255,.82);
      font-size: 14.5px; font-weight: 700;
      transition: background .2s, border-color .2s;
    }
    .social-btn:hover { background: rgba(255,255,255,.12); border-color: rgba(255,255,255,.32); }
    .social-btn .si { font-size: 18px; }
    .join-road {
      max-width: 720px; margin: 0 auto;
      padding: 34px 40px; border-radius: 22px;
      background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.11);
    }
    .join-road h4 {
      font-size: 11px; font-weight: 700; color: var(--accent);
      letter-spacing: 2.5px; text-transform: uppercase; margin-bottom: 26px;
    }
    .road-items { display: flex; flex-direction: column; gap: 18px; text-align: left; }
    .road-item  { display: flex; gap: 18px; align-items: center; }
    .road-date  { font-size: 12.5px; font-weight: 700; color: var(--accent); min-width: 115px; text-align: right; }
    .road-dot   { width: 9px; height: 9px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
    .road-dot.dim { background: rgba(255,255,255,.20); }
    .road-text  { font-size: 14.5px; color: rgba(255,255,255,.72); font-weight: 500; }
    .road-text strong { color: #fff; font-weight: 700; }

    footer {
      background: #040e1c; color: rgba(255,255,255,.40);
      text-align: center; padding: 26px 20px; font-size: 13.5px;
    }
    footer a { color: rgba(255,255,255,.55); }
    footer a:hover { color: rgba(255,255,255,.85); }

    @media (max-width: 1020px) {
      .thinking-grid   { grid-template-columns: repeat(2,1fr); }
      .platform-grid   { grid-template-columns: 1fr; max-width: 460px; margin: 0 auto; }
      .mission-pillars { grid-template-columns: repeat(2,1fr); }
    }
    @media (max-width: 780px) {
      .nav-links, .nav-cta { display: none; }
      .hamburger { display: flex; }
      .hero {
        background:
          linear-gradient(180deg, rgba(7,18,37,.95) 0%, rgba(7,18,37,.78) 50%, rgba(7,18,37,.38) 100%),
          url("hero-thinking.png") center top / cover no-repeat;
      }
      .hero-inner { max-width: 100%; margin: 0 20px; padding: 56px 0 120px; }
      .section { padding: 72px 20px; }
      .challenge-grid { grid-template-columns: 1fr; }
      .thinking-grid  { grid-template-columns: 1fr; }
      .why-grid       { grid-template-columns: 1fr; }
      .rootgene-box   { padding: 36px 26px; }
      .flow           { gap: 4px; }
      .flow-step .f-zh { font-size: 18px; }
      .join-form      { flex-direction: column; }
      .join-social    { flex-direction: column; align-items: center; }
      .join-road      { padding: 28px 22px; }
      .road-date      { min-width: 88px; font-size: 11.5px; }
    }
    @media (max-width: 480px) {
      .mission-pillars { grid-template-columns: 1fr; }
      .c-side          { padding: 28px 22px; }
      .rootgene-box    { padding: 28px 20px; }
      .mission-question { padding: 30px 24px; }
    }
  </style>
</head>
