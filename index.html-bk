<section class="section why-section" id="why-chess">
  <div class="section-inner">
    <div class="section-label">Why Chess</div>
    <h2 class="section-title">
      &#26827;&#19981;&#26159;&#25105;&#20204;&#30340;&#30446;&#30340;&#12290;<br>
      &#26827;&#26159;&#25105;&#20204;&#30340;<span style="color:var(--blue)">&#23454;&#39564;&#23460;</span>&#12290;
    </h2>
    <p class="section-sub">
      &#22312; MindsEvo&#65292;&#25105;&#20204;&#20960;&#20046;&#19981;&#35805;&#26827;&#33402;&#26412;&#36523;&#12290;<br>
      &#26827;&#26159;&#26234;&#24942;&#35757;&#32451;&#30340;&#29615;&#22659;&#19982;&#36807;&#31243;&#8212;&#8212;&#35753;&#24605;&#32500;&#21464;&#24471;&#21487;&#35265;&#12289;&#21487;&#32451;&#12289;&#21487;&#36827;&#21270;&#30340;&#23454;&#39564;&#23460;&#12290;
    </p>

    <div class="why-grid">
      <div>
        <h3 style="font-size:20px;font-weight:850;margin-bottom:26px;">&#20026;&#20160;&#20040;&#26827;&#31867;&#26159;&#26368;&#22909;&#30340;&#31532;&#19968;&#20010;&#36733;&#20307;&#65311;</h3>
        <div class="why-reasons">
          <div class="why-reason">
            <div class="ic">&#127919;</div>
            <div>
              <h4>&#35268;&#21017;&#31616;&#21333;&#65292;&#30693;&#35782;&#38376;&#27835;&#26극;&#20302;</h4>
              <p>&#19981;&#38656;&#35201;&#31215;&#31215;&#22823;&#37327;&#32972;&#26223;&#30693;&#35782;&#65292;&#20219;&#20309;&#20154;&#37117;&#21487;&#20197;&#24555;&#36895;&#24320;&#22987;&#24605;&#32500;&#35757;&#32451;&#12290;</p>
            </div>
          </div>
          <div class="why-reason">
            <div class="ic">&#9889;</div>
            <div>
              <h4>&#21363;&#26102;&#21453;&#39304;&#65292;&#24555;&#36895;&#39564;&#35777;</h4>
              <p>&#27ỗng;&#19968;&#27493;&#37117;&#20250;&#31354;&#21363;&#20135;&#29983;&#32467;&#26524;&#65292;&#24605;&#32500;&#30340;&#23545;&#38ai;&#21487;&#20197;&#34987;&#24555;&#36895;&#26816;&#39564;&#21644;&#20462;&#27491;&#12290;</p>
            </div>
          </div>
          <div class="why-reason">
            <div class="ic">&#128260;</div>
            <div>
              <h4>&#35ử;&#38ai;&#19982;&#36845;&#20195;&#22825;&#28982;&#20869;&#23884;</h4>
              <p>&#26827;&#23616;&#26412;&#36523;&#23601;&#26159;&#21453;&#22797;&#35ử;&#38ai;&#30340;&#36807;&#31243;&#65292;&#21551;&#21457;&#24335;&#23398;&#20064;&#22312;&#27492;&#29615;&#22659;&#20013;&#33258;&#28982;&#21457;&#29983;&#12290;</p>
            </div>
          </div>
          <div class="why-reason">
            <div class="ic">&#129504;</div>
            <div>
              <h4>&#36923;&#36753;&#19982;&#20915;&#31574;&#23494;&#24230;&#26极;&#39640;</h4>
              <p>&#27ỗng;&#19968;&#27493;&#37117;&#21253;&#21547;&#35745;&#21010;&#12289;&#39044;&#21028;&#12289;&#21462;&#33411;&#8212;&#8212;&#24605;&#32500;&#35757;&#32451;&#23494;&#24230;&#36828;&#36229;&#22823;&#22810;&#25968;&#23398;&#20064;&#22330;&#26222;&#12290;</p>
            </div>
          </div>
          <div class="why-reason">
            <div class="ic">&#127807;</div>
            <div>
              <h4>&#20174;&#27169;&#20223;&#21040;&#29420;&#31435;&#24605;&#32771;&#65292;&#36335;&#24452;&#28165;&#26224;</h4>
              <p>&#26159;&#35266;&#23519;&#21644;&#22521;&#20808;&#24605;&#32500;&#25104;&#38271;&#36807;&#31243;&#26368;&#29702;&#24819;&#30340;&#29615;&#22659;&#20043;&#19968;&#65292;&#21551;&#21457;&#33258;&#23398;&#26412;&#36523;&#23601;&#20855;&#26377;&#24040;&#22823;&#20215;&#20540;&#12290;</p>
            </div>
          </div>
        </div>
      </div>

      <div class="why-labs">
        <div class="why-labs-head">&#19977;&#31181;&#19981;&#21516;&#30340;&#24605;&#32500;&#23454;&#39564;&#23460;</div>
        <div class="lab-card">
          <div class="lab-name">CogniChess</div>
          <div class="lab-sub">A Laboratory for Strategic Thinking</div>
          <p>&#22269;&#38469;&#35937;&#26827;&#30340;&#35268;&#21017;&#19982;&#21464;&#21270;&#65292;&#22825;&#28982;&#35757;&#32451;&#35745;&#21010;&#33021;&#21147;&#12289;&#39044;&#21028;&#21147;&#19982;&#26524;&#26029;&#20915;&#31574;&#12290;&#24378;&#35843;&#36923;&#36753;&#25512;&#23548;&#19982;&#21518;&#26524;&#35780;&#20215;&#12290;</p>
        </div>
        <div class="lab-card">
          <div class="lab-name">CogniXiangqi</div>
          <div class="lab-sub">A Laboratory for Tactical Thinking</div>
          <p>&#20013;&#22269;&#35937;&#26827;&#30340;&#25112;&#26415;&#33410;&#22863;&#19982;&#23616;&#38754;&#29702;&#35299;&#65292;&#24378;&#21270;&#30452;&#35273;&#21028;&#26029;&#19982;&#36164;&#28304;&#21327;&#35843;&#65292;&#20307;&#29616;&#25972;&#20307;&#35266;&#19982;&#21160;&#24577;&#24179;&#34900;&#12290;</p>
        </div>
        <div class="lab-card">
          <div class="lab-name">CogniGo</div>
          <div class="lab-sub">A Laboratory for Complex Thinking</div>
          <p>&#22260;&#26827;&#30340;&#26080;&#31294;&#21464;&#21270;&#19982;&#20840;&#23616;&#35266;&#65292;&#35757;&#32451;&#22312;&#39640;&#24230;&#19981;&#30830;&#23450;&#24615;&#20013;&#30340;&#20915;&#31574;&#33021;&#21147;&#65292;&#20197;&#21450;&#23545;&#21183;&#19982;&#24418;&#30340;&#25象;&#35266;&#29702;&#35299;&#12290;</p>
        </div>
      </div>
    </div>

    <div class="why-conclusion">
      &#26827;&#31867;&#26159;&#30446;&#21069;&#20154;&#31867;&#24050;&#32463;&#21019;&#36896;&#20986;&#30340;&#12289;&#26368;&#25104;&#29087;&#12289;&#26368;&#23481;&#26131;&#23454;&#36341;&#30340;<em>&#24605;&#32500;&#35757;&#32451;&#29615;&#22659;</em>&#20043;&#19968;&#12290;<br>
      &#36825;&#26159;&#25105;&#20204;&#36873;&#25321;&#23427;&#20316;&#20026;&#31532;&#19968;&#20010;&#23454;&#39564;&#23460;&#30340;&#29702;&#30001;&#12290;
      <small>&#22914;&#26524;&#19977;&#22823;&#26827;&#25104;&#21151;&#65292;MindsEvo &#30340;&#20351;&#21629;&#23558;&#24310;&#20280;&#21040;&#25968;&#23398;&#12289;&#31185;&#23398;&#12289;&#32534;&#31243;&#24605;&#32500;&#8230;&#8230;&#20197;&#21450;&#19968;&#20999;&#21487;&#20197;&#35757;&#32451;&#20154;&#31867;&#26234;&#24942;&#30340;&#39046;&#22495;&#12290;</small>
    </div>
  </div>
