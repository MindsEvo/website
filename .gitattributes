# Normalize line endings for all text files to LF in the repository
* text=auto eol=lf

# Explicitly declare text files
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.svg     text eol=lf

# Binary files — no line ending conversion
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.wasm    binary
